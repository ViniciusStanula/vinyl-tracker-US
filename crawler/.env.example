# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Transaction Pooler recommended)
# Supabase: Settings → Database → Connection string → URI → Transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@[host]:6543/postgres"

# ── Amazon Associates ─────────────────────────────────────────────────────────
# Affiliate tag appended to Amazon product URLs — leave empty to omit
ASSOCIATE_TAG=""

# ── Last.fm ───────────────────────────────────────────────────────────────────
# API key for fetching artist genre tags — get one free at https://www.last.fm/api/account/create
LASTFM_API_KEY=""

# ── Cache revalidation ────────────────────────────────────────────────────────
# Full URL of the Next.js revalidation endpoint (e.g. https://your-domain.com/api/revalidate)
REVALIDATE_URL=""
# Secret token that authorizes the revalidation request — must match REVALIDATE_SECRET in frontend
REVALIDATE_SECRET=""

# ── IndexNow ──────────────────────────────────────────────────────────────────
# Key for IndexNow URL submission — generate one at https://www.bing.com/indexnow
INDEXNOW_KEY=""
# Your production domain without https:// (e.g. "www.example.com")
INDEXNOW_HOST=""

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Comma-separated list of proxy URLs — leave empty to crawl without proxies
PROXY_LIST=""
# Path to a file with one proxy URL per line (alternative to PROXY_LIST)
PROXY_FILE=""
