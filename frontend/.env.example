# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Transaction Pooler recommended for serverless)
# Supabase: Settings → Database → Connection string → URI → Transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@[host]:6543/postgres"

# ── Site ──────────────────────────────────────────────────────────────────────
# Your production domain — used for canonical URLs, OG tags, and sitemap base
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ── Cache revalidation ────────────────────────────────────────────────────────
# Secret token used by the crawler to trigger ISR revalidation after each crawl
# Must match REVALIDATE_SECRET in the crawler environment
REVALIDATE_SECRET="change-me-to-a-long-random-string"
